# App
APP_NAME=DeepLook
APP_ENV=development
DEBUG=true
API_SECRET_KEY=<random-32-char-string>
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJI...
# Pooler URL (used by the app at runtime) — from Supabase > Settings > Database > Connection string > Session mode
DATABASE_URL=postgresql+asyncpg://postgres.projectref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Direct URL (used by Alembic for migrations) — from Supabase > Settings > Database > Connection string > Direct connection
DIRECT_DATABASE_URL=postgresql+asyncpg://postgres:password@db.projectref.supabase.co:5432/postgres

# AI Providers (only the active one is required)
# AI_PROVIDER options: openai, anthropic, gemini, mock
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# File Upload
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_UPLOAD=100

# Clerk Authentication
# Get JWKS URL from Clerk Dashboard → Configure → API Keys → Advanced → JWT verification
# CLERK_JWKS_URL format:  https://<your-clerk-domain>/.well-known/jwks.json
# CLERK_ISSUER is the same base domain (no trailing slash, no path)
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>

# Meta WhatsApp (Phase 2 — optional for MVP)
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=

# WAHA Integration
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=<generate-a-long-random-key>
WAHA_WEBHOOK_SECRET=
# false = WAHA Core free (only "default" session). true = WAHA PLUS (unique session per client).
WAHA_MULTI_SESSION=false
# Max DM chats (conversations) included per sync — most-recently-active first (0 = no limit)
WAHA_MAX_CHATS=100

# WhatsApp Scheduler
ENABLE_WHATSAPP_SCHEDULER=true
WHATSAPP_SCHEDULER_INTERVAL_MINUTES=15

# Billing gate (set true in production to enforce plan checks)
ENFORCE_BILLING=false

# Wompi — Colombian payment gateway (comercios.wompi.co)
# Use pub_stagtest_ / stagtest_ keys for development, pub_prod_ / prod_ for production
WOMPI_PUBLIC_KEY=pub_test_9
WOMPI_INTEGRITY_SECRET=test_integrity_P
WOMPI_EVENTS_SECRET=test_events_o

# Prices in COP centavos (79000 COP = 7900000)
WOMPI_PRICE_BASIC_CENTS=160000
WOMPI_PRICE_PLUS_CENTS=250000
WOMPI_PRICE_ENTERPRISE_CENTS=400000

# Base URL for payment redirect (your frontend, no trailing slash)
WOMPI_REDIRECT_BASE_URL=http://localhost:5173
